{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/nrjdalal/nrjdalal/main/scripts/sync.schema.json",
  "title": "sync.json",
  "description": "Config for scripts/sync.ts — which $HOME files to mirror into user/, grouped, with optional post-restore build steps.",
  "type": "object",
  "required": ["version", "groups"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version, for forward-compatible migrations."
    },
    "groups": {
      "type": "object",
      "description": "Named groups of config to back up / restore.",
      "additionalProperties": { "$ref": "#/$defs/group" }
    }
  },
  "$defs": {
    "group": {
      "type": "object",
      "required": ["files"],
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "description": "Files mirrored between $HOME and user/.",
          "items": { "$ref": "#/$defs/entry" }
        },
        "run": {
          "type": "string",
          "description": "Command run AFTER this group is restored, e.g. to regenerate a derived file (\"npx karabiner-human-config\")."
        },
        "cwd": {
          "type": "string",
          "description": "Working directory for `run`, relative to $HOME. Defaults to $HOME."
        }
      }
    },
    "entry": {
      "oneOf": [
        {
          "type": "string",
          "description": "Path relative to $HOME, mirrored to user/<path> (e.g. \".config/cmux/cmux.json\")."
        },
        {
          "type": "object",
          "required": ["to"],
          "additionalProperties": false,
          "properties": {
            "from": {
              "type": "string",
              "description": "Source path relative to $HOME. Defaults to `to` when omitted."
            },
            "to": {
              "type": "string",
              "description": "Path relative to user/ (the $HOME mirror)."
            }
          }
        }
      ]
    }
  }
}
