{
  "$schema": "./sync.schema.json",
  "version": 1,
  "groups": {
    "claude": {
      "files": [
        ".claude/statusline.sh",
        ".claude/settings.json"
      ]
    },
    "cmux": {
      "files": [
        ".config/cmux/cmux.json",
        ".config/cmux/settings.json"
      ]
    },
    "cmux-workspaces": {
      "files": [".config/cmux/workspaces.ts"]
    },
    "code": {
      "files": [
        { "from": "Library/Application Support/Code/User/settings.json", "to": ".config/vscode/settings.json" }
      ]
    },
    "code-extensions": {
      "files": [".config/vscode/extensions.txt"],
      "pre": { "cmd": "code --list-extensions > extensions.txt", "cwd": ".config/vscode" },
      "post": { "cmd": "xargs -L1 code --install-extension < extensions.txt", "cwd": ".config/vscode" }
    },
    "ghostty": {
      "files": [".config/ghostty/config"]
    },
    "git": {
      "files": [".gitconfig"]
    },
    "karabiner": {
      "files": [".config/karabiner/konfig.json"],
      "post": { "cmd": "npx karabiner-human-config", "cwd": ".config/karabiner" }
    }
  }
}
